# ── Database — MySQL with aiomysql driver ────────────────────────────────────
DATABASE_URL=mysql+aiomysql://lms_user:lms_password@db:3306/lms_db

# ── Must match DJANGO_SECRET_KEY exactly ──────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-50-char-random-string-before-use

# ── Redis — use service name "redis", NOT localhost ───────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
