# ── Core ──────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-50-char-random-string-before-use
DEBUG=True
ALLOWED_HOSTS=*

# ── Database — MySQL (service name "db", NOT localhost) ───────────────────────
DB_NAME=lms_db
DB_USER=lms_user
DB_PASSWORD=lms_password
DB_HOST=db
DB_PORT=3306

# ── Redis — use service name "redis", NOT localhost ───────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Stripe (optional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── S3 (disabled by default) ──────────────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ── Email (prints to console in dev) ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
